---
const features = [
  { icon: "📘", text: "Información" },
  { icon: "🤝", text: "Acompañamiento" },
  { icon: "🧠", text: "Apoyo emocional" },
  { icon: "📍", text: "Apoyo logístico" },
  { icon: "💊", text: "Aborto con medicamentos" },
];
---

<section
  id="aborto-seguro"
  class="py-12 sm:py-20"
  style="background: var(--green-gradient);"
  aria-labelledby="abortion-title"
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <h2
      id="abortion-title"
      class="text-2xl font-bold text-white sm:text-3xl text-center"
    >
      Tu decisión, tu derecho.
    </h2>
    <p class="mt-6 text-center text-base leading-[1.6] text-white/95">
      Red de acompañamiento para la interrupción legal del embarazo en México y
      Latinoamérica.
    </p>
    <div
      class="mt-10 flex flex-wrap justify-center items-center gap-4 lg:gap-6"
    >
      {
        features.map((f) => (
          <div class="flex items-center gap-3">
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/10 text-base"
              aria-hidden="true"
            >
              {f.icon}
            </span>
            <span class="text-base text-white/90">{f.text}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
