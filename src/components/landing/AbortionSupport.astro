---
const features = [
  { icon: "📘", text: "información" },
  { icon: "🤝", text: "acompañamiento" },
  { icon: "🧠", text: "apoyo emocional" },
  { icon: "📍", text: "apoyo logístico" },
  { icon: "💊", text: "aborto con medicamentos" },
];
---

<section
  id="aborto-seguro"
  class="py-12 sm:py-20"
  style="background: linear-gradient(180deg, #053e2f 0%, #045230 100%);"
  aria-labelledby="abortion-title"
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6">
    <h2
      id="abortion-title"
      class="text-2xl font-bold text-white sm:text-3xl text-center"
      style="font-weight: 700;"
    >
      Tu decisión, tu derecho.
    </h2>
    <p
      class="mt-6 text-center text-white/95 leading-[1.6]"
      style="font-size: 16px;"
    >
      Red de acompañamiento para la interrupción legal del embarazo en México y
      Latinoamérica.
    </p>
    <div class="mt-6 flex flex-wrap justify-center items-center gap-4">
      {
        features.map((f) => (
          <div class="flex items-center gap-3" style="gap: 12px;">
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-base"
              style="width: 36px; height: 36px; border-radius: 999px; background: rgba(255,255,255,0.1);"
              aria-hidden="true"
            >
              {f.icon}
            </span>
            <span style="color: rgba(255,255,255,0.9); font-size: 16px;">
              {f.text}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
