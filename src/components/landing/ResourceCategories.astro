---
// filterType = value used in DirectoryFilters (SUPPORT_TYPES). Multiple for "Organizaciones".
const categories = [
  {
    name: "Líneas de crisis",
    icon: "📞",
    description: "Atención 24 h. Gratuita.",
    filterTypes: ["crisis hotline"],
  },
  {
    name: "Colectivas",
    icon: "👥",
    description: "Redes y colectivas feministas.",
    filterTypes: ["community support"],
  },
  {
    name: "Acompañamiento ILE",
    icon: "🌿",
    description: "Acompañamiento seguro y gratuito.",
    filterTypes: ["abortion accompaniment"],
  },
  {
    name: "Psicólogas",
    icon: "🧠",
    description: "Apoyo psicológico y terapia.",
    filterTypes: ["psychological support"],
  },
  {
    name: "Abogadas",
    icon: "⚖️",
    description: "Asesoría y acompañamiento legal.",
    filterTypes: ["legal support"],
  },
  {
    name: "Organizaciones",
    icon: "🏛",
    description: "ONG y apoyo legal o comunitario.",
    filterTypes: ["legal support", "community support"],
  },
  {
    name: "Recursos gubernamentales",
    icon: "🏢",
    description: "Servicios gratuitos del Estado.",
    filterTypes: ["government services"],
  },
  {
    name: "Nutriólogas",
    icon: "🌿",
    description: "Nutrición y alimentación.",
    filterTypes: ["nutrition support"],
  },
  {
    name: "Médicas y Salud",
    icon: "🩺",
    description: "Salud de la mujer y derecho al cuerpo.",
    filterTypes: ["medical and health", "sexual health"],
  },
  {
    name: "Asociaciones y Fundaciones",
    icon: "🤝",
    description: "Refugios, apoyo legal y psicológico.",
    filterTypes: ["associations and foundations"],
  },
];

function buildDirectorioUrl(filterTypes: string[]): string {
  if (filterTypes.length === 0) return "/directorio";
  const params = new URLSearchParams();
  filterTypes.forEach((t) => params.append("tipo", t));
  return `/directorio?${params.toString()}`;
}
---

<section
  id="categorias"
  class="py-12 sm:py-20 bg-[#f6f6fb]"
  aria-labelledby="categories-title"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2
      id="categories-title"
      class="text-2xl font-bold text-[var(--card-text)] sm:text-3xl text-center mb-10"
    >
      Tipos de recursos
    </h2>
    <ul
      class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
      role="list"
    >
      {
        categories.map((cat) => (
          <li class="h-full">
            <a
              href={buildDirectorioUrl(cat.filterTypes)}
              class="flex flex-col rounded-xl border border-[var(--card-border)] bg-white p-6 transition-transform duration-200 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-[var(--brand-purple-accent)] focus:ring-offset-2 h-full"
              style="box-shadow: var(--card-shadow-soft);"
            >
              <span
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#f3edff] text-2xl"
                aria-hidden="true"
              >
                {cat.icon}
              </span>
              <h3 class="mt-4 text-lg font-semibold text-[var(--card-text)]">
                {cat.name}
              </h3>
              <p class="mt-2 text-base leading-[1.6] text-[var(--card-text-muted)]">
                {cat.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
