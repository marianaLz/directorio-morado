---
// filterType = value used in DirectoryFilters (SUPPORT_TYPES). Multiple for "Organizaciones".
const categories = [
  {
    name: "Colectivas",
    icon: "👥",
    description: "Colectivas feministas y redes de acompañamiento.",
    filterTypes: ["community support"],
  },
  {
    name: "Psicólogas",
    icon: "🧠",
    description: "Apoyo psicológico y emocional para sobrevivientes.",
    filterTypes: ["psychological support"],
  },
  {
    name: "Organizaciones",
    icon: "🏛",
    description: "ONG y asociaciones de apoyo legal y comunitario.",
    filterTypes: ["legal support", "community support"],
  },
  {
    name: "Recursos gubernamentales",
    icon: "🏢",
    description: "Servicios gratuitos del gobierno (CDMX y nacional).",
    filterTypes: ["government services"],
  },
  {
    name: "Líneas de crisis",
    icon: "📞",
    description: "Atención 24 horas. Gratuita en todo México.",
    filterTypes: ["crisis hotline"],
  },
];

function buildDirectorioUrl(filterTypes: string[]): string {
  if (filterTypes.length === 0) return "/directorio";
  const params = new URLSearchParams();
  filterTypes.forEach((t) => params.append("tipo", t));
  return `/directorio?${params.toString()}`;
}
---

<section
  id="categorias"
  class="py-12 sm:py-20 bg-[#f6f6fb]"
  aria-labelledby="categories-title"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <h2
      id="categories-title"
      class="text-2xl font-bold text-[var(--card-text)] sm:text-3xl text-center mb-10"
    >
      Tipos de recursos
    </h2>
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        categories.map((cat) => (
          <li class="h-full">
            <a
              href={buildDirectorioUrl(cat.filterTypes)}
              class="flex flex-col rounded-xl border border-[var(--card-border)] bg-white p-6 transition-transform duration-200 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-[var(--brand-purple-accent)] focus:ring-offset-2 h-full"
              style="box-shadow: var(--card-shadow-soft);"
            >
              <span
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#f3edff] text-2xl"
                aria-hidden="true"
              >
                {cat.icon}
              </span>
              <h3 class="mt-4 text-lg font-semibold text-[var(--card-text)]">
                {cat.name}
              </h3>
              <p class="mt-2 text-base leading-[1.6] text-[var(--card-text-muted)]">
                {cat.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
