---
import { faqItems } from "../../data/faq";

interface Props {
  /** Max number of questions to show. If set, a "Ver todas" link is shown. */
  limit?: number;
}

const { limit } = Astro.props;
const items = limit ? faqItems.slice(0, limit) : faqItems;
const showAllLink = limit != null && faqItems.length > limit;
---

<section
  id="preguntas-frecuentes"
  class="py-12 sm:py-20 bg-white"
  aria-labelledby="faq-title"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <h2 id="faq-title" class="text-2xl font-bold text-[var(--card-text)] sm:text-3xl text-center mb-10">
      Preguntas frecuentes
    </h2>
    <dl class="space-y-4">
      {
        items.map((faq) => (
          <div
            class="rounded-xl border border-[var(--card-border)] bg-white p-5 transition-transform duration-200 hover:-translate-y-0.5"
            style="box-shadow: var(--card-shadow-soft);"
          >
            <dt id={faq.id} class="text-lg font-semibold text-[var(--card-text)]">
              {faq.question}
            </dt>
            <dd class="mt-3 text-base leading-[1.6] text-[var(--card-text-muted)]" aria-labelledby={faq.id}>
              {faq.answer}
            </dd>
          </div>
        ))
      }
    </dl>
    {
      showAllLink && (
        <p class="mt-8 text-center">
          <a
            href="/preguntas-frecuentes"
            class="text-[var(--brand-purple-accent)] font-semibold underline hover:text-[var(--brand-purple-deeper)] focus:outline-none focus:ring-2 focus:ring-[var(--brand-purple-accent)] focus:ring-offset-2 rounded"
          >
            Ver todas las preguntas
          </a>
        </p>
      )
    }
  </div>
</section>
