---
import { faqItems } from '../../data/faq';

interface Props {
  /** Max number of questions to show. If set, a "Ver todas" link is shown. */
  limit?: number;
}

const { limit } = Astro.props;
const items = limit ? faqItems.slice(0, limit) : faqItems;
const showAllLink = limit != null && faqItems.length > limit;
---
<section
  id="preguntas-frecuentes"
  class="py-12 sm:py-20 bg-[#ffffff]"
  aria-labelledby="faq-title"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <h2 id="faq-title" class="text-2xl font-bold text-[#1a1a1a] sm:text-3xl text-center mb-10" style="font-weight: 700;">
      Preguntas frecuentes
    </h2>
    <dl class="space-y-4">
      {items.map((faq) => (
        <div
          class="rounded-[12px] border border-[rgba(0,0,0,0.08)] bg-white p-5 transition-transform duration-200 hover:-translate-y-0.5"
          style="box-shadow: 0 6px 20px rgba(0,0,0,0.06);"
        >
          <dt id={faq.id} class="text-lg font-semibold text-[#1a1a1a]" style="font-weight: 700;">
            {faq.question}
          </dt>
          <dd class="mt-3 text-[#4b5563] leading-[1.6]" style="font-size: 16px;" aria-labelledby={faq.id}>
            {faq.answer}
          </dd>
        </div>
      ))}
    </dl>
    {showAllLink && (
      <p class="mt-8 text-center">
        <a
          href="/preguntas-frecuentes"
          class="text-[#5f24af] font-semibold underline hover:text-[#260e4c] focus:outline-none focus:ring-2 focus:ring-[#5f24af] focus:ring-offset-2 rounded"
          style="font-weight: 600;"
        >
          Ver todas las preguntas
        </a>
      </p>
    )}
  </div>
</section>
