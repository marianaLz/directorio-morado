---
const crisisPhone = '8009112000';
const crisisPhoneDisplay = '800 911 2000';
---
<section
  id="linea-de-crisis"
  class="py-12 sm:py-20"
  style="background: linear-gradient(180deg, #b71c1c 0%, #e53935 100%);"
  aria-labelledby="crisis-title"
  role="region"
  aria-label="Línea de crisis 24 horas"
>
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6">
    <p id="crisis-label" class="text-base font-semibold text-white">
      Línea de ayuda en crisis
    </p>
    <p class="mt-1 text-sm text-white/95">
      24 horas · Gratuita · Todo México
    </p>
    <p class="mt-6 text-3xl font-bold tracking-tight text-white sm:text-4xl">
      {crisisPhoneDisplay}
    </p>
    <a
      href={`tel:${crisisPhone}`}
      class="mt-6 inline-flex min-h-[56px] min-w-[200px] items-center justify-center rounded-[10px] bg-white px-8 py-4 text-lg font-bold text-[#b71c1c] shadow-lg hover:bg-white/95 focus:outline-none focus:ring-4 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#e53935]"
      aria-label="Llamar ahora al 800 911 2000"
    >
      Llamar ahora
    </a>
  </div>
</section>
