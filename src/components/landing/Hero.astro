---

---

<section
  id="hero"
  class="relative overflow-hidden py-12 sm:py-20"
  style="background: linear-gradient(180deg, #260e4c 0%, #1f0a3d 100%);"
  aria-labelledby="hero-title"
>
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
    <h1
      id="hero-title"
      class="text-3xl font-bold tracking-tight text-[var(--color-highlight)] sm:text-4xl md:text-5xl"
    >
      Directorio Morado
    </h1>
    <p class="mt-4 text-xl font-medium text-[var(--color-title)] sm:text-2xl">
      Red de apoyo · MX
    </p>
    <p class="mt-6 text-base leading-[1.6] text-[var(--color-highlight)]/90">
      Directorio de recursos de apoyo para sobrevivientes de violencia sexual en
      México.
    </p>
    <p
      class="mt-4 text-base font-medium leading-[1.6] text-[var(--color-highlight)]/95"
    >
      No estás solx. Hay personas que pueden ayudarte.
    </p>
    <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
      <a
        href="/directorio"
        class="inline-flex min-h-[48px] w-full items-center justify-center rounded-xl bg-[#5f24af] px-5 py-3 text-base font-semibold text-white shadow-lg transition-colors hover:bg-[#7030c4] focus:outline-none focus:ring-4 focus:ring-[var(--color-title)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg-top)] sm:w-auto"
      >
        Explorar directorio
      </a>
      <a
        href="#como-usar"
        class="inline-flex min-h-[48px] w-full items-center justify-center rounded-xl border-2 border-[var(--color-title)] bg-transparent px-5 py-3 text-base font-semibold text-[var(--color-highlight)] transition-colors hover:bg-white/10 focus:outline-none focus:ring-4 focus:ring-[var(--color-title)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg-top)] sm:w-auto"
      >
        Cómo usar este directorio
      </a>
    </div>
  </div>
</section>
