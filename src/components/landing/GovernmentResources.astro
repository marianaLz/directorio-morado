---
import type { DirectoryEntry } from "../../types/directory";
import directoryData from "../../data/directory.json";

const entries = (directoryData as DirectoryEntry[]).filter((e) =>
  e.type.includes("government services"),
);
---

<section
  id="recursos-gubernamentales"
  class="py-12 sm:py-20 bg-[#f6f6fb]"
  aria-labelledby="gov-section-title"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-6 flex flex-wrap items-center gap-2">
      <span
        class="inline-block rounded-xl bg-[var(--tag-government-bg)] px-2.5 py-1 text-xs font-semibold text-[var(--tag-government-text)]"
        aria-hidden="true"
      >
        🏛 Oficial
      </span>
    </div>
    <h2
      id="gov-section-title"
      class="text-2xl font-bold text-[var(--card-text)] sm:text-3xl"
    >
      Recursos gubernamentales
    </h2>
    <p class="mt-3 text-base leading-[1.6] text-[var(--card-text-muted)]">
      Servicios gratuitos del gobierno · CDMX y Nacional
    </p>
    <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        entries.map((entry) => (
          <li class="h-full">
            <article
              class="flex flex-col h-full rounded-xl border-l-4 border-[var(--brand-purple-light)] bg-white p-5 transition-transform duration-200 hover:-translate-y-0.5"
              style="box-shadow: var(--card-shadow-soft);"
              aria-labelledby={`gov-${entry.id}`}
            >
              <h3
                id={`gov-${entry.id}`}
                class="text-lg font-semibold text-[var(--card-text)]"
              >
                {entry.name}
              </h3>
              {entry.location && (
                <p class="mt-2 text-sm text-[#4b5563] leading-[1.6]">
                  <span class="font-medium">Ubicación:</span> {entry.location}
                </p>
              )}
              {entry.hours && (
                <p class="mt-1 text-sm text-[#4b5563] leading-[1.6]">
                  <span class="font-medium">Horario:</span> {entry.hours}
                </p>
              )}
              <p class="mt-3 text-base leading-[1.6] text-[var(--card-text)] flex-1">
                {entry.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="inline-flex items-center rounded-xl bg-[var(--tag-government-bg)] px-2.5 py-1 text-xs font-medium text-[var(--tag-government-text)]">
                  Gratuito
                </span>
              </div>
              <div class="mt-5 flex flex-wrap gap-3">
                {entry.website && (
                  <a
                    href={entry.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center min-h-[48px] rounded-xl bg-[#5f24af] px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#7030c4]"
                    aria-label={`Ver sitio web de ${entry.name}`}
                  >
                    Ver sitio web
                  </a>
                )}
                {entry.instagram && (
                  <a
                    href={`https://instagram.com/${entry.instagram.replace("@", "")}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center min-h-[48px] rounded-xl border border-[rgba(0,0,0,0.12)] px-4 py-3 text-sm font-semibold text-[#1a1a1a] transition-colors hover:bg-[#fafafa]"
                    aria-label={`Contactar a ${entry.name} por Instagram`}
                  >
                    Instagram
                  </a>
                )}
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
