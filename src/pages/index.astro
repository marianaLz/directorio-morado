---
import Layout from "../layouts/Layout.astro";
import EmergencyBanner from "../components/EmergencyBanner.astro";
import Hero from "../components/landing/Hero.astro";
import HowToUse from "../components/landing/HowToUse.astro";
import ResourceCategories from "../components/landing/ResourceCategories.astro";
import AbortionSupport from "../components/landing/AbortionSupport.astro";
import GovernmentResources from "../components/landing/GovernmentResources.astro";
import FAQ from "../components/landing/FAQ.astro";
import CtaSection from "../components/landing/CtaSection.astro";
import AboutThisDirectory from "../components/landing/AboutThisDirectory.astro";
import { faqItems } from "../data/faq";
import { buildFAQPageSchema } from "../data/schema";

const faqSchema = buildFAQPageSchema(
  faqItems.map((item) => ({ name: item.question, text: item.answer })),
);
---

<Layout
  title="Directorio Morado — Red de apoyo para sobrevivientes de violencia sexual en México"
  description="Directorio Morado es una red de apoyo que conecta a sobrevivientes de violencia sexual con organizaciones, psicólogas, colectivas y recursos en México y Latinoamérica."
  structuredData={[faqSchema]}
>
  <EmergencyBanner slot="emergency" />
  <Hero />
  <ResourceCategories />
  <AbortionSupport />
  <GovernmentResources />
  <FAQ limit={3} />
  <CtaSection />
  <AboutThisDirectory />
</Layout>
