rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Directorio público: lectura para todos; escritura solo admin (emails permitidos)
    match /directory/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'marianaglp15@gmail.com'
      ];
    }
    // Solicitudes pendientes: cualquiera puede crear; leer/editar/eliminar solo admin
    match /directory_pending/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email in [
        'marianaglp15@gmail.com'
      ];
    }
  }
}