rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Directorio público: solo lectura para todo el mundo
    match /directory/{docId} {
      allow read: if true;
      allow write: if false;
    }
    // Solicitudes pendientes de aprobación: cualquiera puede crear, nadie puede leer/editar (solo Admin/backend)
    match /directory_pending/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}